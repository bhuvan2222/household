NODE_ENV=development
PORT=4000
CLIENT_ORIGINS=http://localhost:8081
# Optional legacy fallback (still supported): CLIENT_ORIGIN=http://localhost:8081
DATABASE_URL=postgres://postgres:postgres@localhost:5432/household_expense
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=replace-with-your-google-client-id.apps.googleusercontent.com
# Optional: comma-separated list to support multiple app audiences (web/android/ios)
# GOOGLE_CLIENT_IDS=web-id.apps.googleusercontent.com,android-id.apps.googleusercontent.com,ios-id.apps.googleusercontent.com
